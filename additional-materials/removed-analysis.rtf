## Shakesnider fines\
\
```\{r\}\
shakesnider_monthly_fines <- unhoused_distinct |> \
  filter(refined_name == "SHAKESNIDER, KEVIN P") |> \
  group_by(off_floor_mo) |> \
  summarise(\
    fined_this_month = sum(amount_fined, na.rm = TRUE),\
